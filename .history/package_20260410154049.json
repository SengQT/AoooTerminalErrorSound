{
  "name": "aooo-terminal-error-sound",
  "displayName": "Aooo Terminal Error Sound (Chowayo)",
  "description": "Plays the iconic Chowayo pumpkin howl when terminal commands fail (non-zero exit codes)",
  "version": "0.0.3",
  "publisher": "sengqt",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/SengQT/AoooTerminalErrorSound"
  },
  "keywords": [
    "terminal",
    "error",
    "sound",
    "audio",
    "chowayo",
    "pumpkin",
    "notification",
    "failed-command"
  ],
  "categories": [
    "Other"
  ],
  "engines": {
    "vscode": "^^1.115.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
"contributes": {
    "commands": [
      {
        "command": "aooo.chowayo",
        "title": "Aooo: Play Chowayo Sound"
      }
    ],
    "configuration": {
      "title": "Aooo Terminal Error Sound",
      "properties": {
        "aooo.enableSound": {
          "type": "boolean",
          "default": true,
          "description": "Enable or disable the Chowayo howl on terminal failure."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.4.5"
  },
  "license": "MIT"
}
